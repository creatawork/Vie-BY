<template>
  <view class="page">
    <!-- 顶部搜索 -->
    <view class="header">
      <view class="search-bar" @click="handleSearch">
        <text class="search-icon">🔍</text>
        <input class="search-input" v-model="searchKeyword" placeholder="搜索商品" @confirm="handleSearch" />
      </view>
    </view>

    <!-- 筛选工具栏 (吸顶) -->
    <view class="filter-bar">
      <!-- 分类 Tab -->
      <scroll-view class="category-scroll" scroll-x="true" show-scrollbar="false">
        <view class="category-tabs">
          <view class="tab-item" @click="selectCategory('all')">
            <text class="tab-text" :class="{ 'tab-text-active': activeCategory === 'all' }">全部</text>
            <view class="active-line" v-if="activeCategory === 'all'"></view>
          </view>
          <view class="tab-item" v-for="cat in categories" :key="cat.id" 
            @click="selectCategory(cat.id)">
            <text class="tab-text" :class="{ 'tab-text-active': activeCategory === cat.id }">{{ cat.name }}</text>
            <view class="active-line" v-if="activeCategory === cat.id"></view>
          </view>
        </view>
      </scroll-view>

      <!-- 排序 Tab -->
      <view class="sort-tabs">
        <view class="sort-item" :class="{ 'sort-item-active': activeSort === 'default' }" @click="selectSort('default')">
          <text>综合</text>
        </view>
        <view class="sort-item" :class="{ 'sort-item-active': activeSort === 'sales' }" @click="selectSort('sales')">
          <text>销量</text>
        </view>
        <view class="sort-item" :class="{ 'sort-item-active': activeSort.includes('price') }" @click="togglePriceSort">
          <text>价格</text>
          <view class="sort-arrows">
            <text class="arrow arrow-up" :class="{ 'arrow-on': activeSort === 'price_asc' }">▲</text>
            <text class="arrow" :class="{ 'arrow-on': activeSort === 'price_desc' }">▼</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 商品列表 -->
    <scroll-view class="product-scroll" scroll-y="true" @scrolltolower="loadMore">
      <view class="product-list">
        <!-- 商品项 (横向卡片) -->
        <view class="product-item" v-for="product in filteredProducts" :key="product.id" @click="goToDetail(product.id)">
          <image class="product-img" :src="product.image" mode="aspectFill"></image>
          <view class="product-content">
            <view class="info-top">
              <text class="product-name">{{ product.name }}</text>
              <text class="product-desc">{{ product.description }}</text>
              <view class="product-tags" v-if="hasTags(product)">
                <text class="tag" v-for="tag in product.tags" :key="tag">{{ tag }}</text>
              </view>
            </view>
            <view class="info-bottom">
              <view class="price-box">
                <text class="currency">¥</text>
                <text class="price">{{ product.price }}</text>
                <text class="origin-price" v-if="product.originalPrice">¥{{ product.originalPrice }}</text>
              </view>
              <view class="add-btn" @click.stop="addToCart(product)">
                <text class="add-icon">+</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view v-if="filteredProducts.length === 0 && !isLoading" class="empty-state">
        <text class="empty-icon">📦</text>
        <text class="empty-text">暂无相关商品</text>
      </view>

      <!-- 加载更多 -->
      <view v-if="isLoading" class="loading-more">
        <text class="loading-text">加载中...</text>
      </view>
      <view v-if="!isLoading && !hasMore && filteredProducts.length > 0" class="no-more">
        <text class="no-more-text">没有更多了</text>
      </view>
    </scroll-view>

    <!-- 悬浮购物车按钮 -->
    <view class="cart-float-btn" @click="goToCart">
      <view class="cart-icon-wrapper">
        <text class="cart-icon">🛒</text>
        <view class="cart-badge" v-if="cartCount > 0">{{ cartCount }}</view>
      </view>
    </view>
    
    <!-- 底部导航栏 -->
    <BottomNav />
  </view>
</template>

<script lang="uts">
import BottomNav from '@/components/BottomNav.uvue'
import { addToCart as addToCartApi, getCartCount, type CartAddParams } from '@/api/cart'
import { getProductDetail } from '@/api/product'
import { post } from '@/utils/request'

type CategoryType = {
  id : string
  name : string
}

type ProductType = {
  id : number
  name : string
  description : string
  image : string
  price : number
  originalPrice? : number
  sales : number
  category : string
  tags? : string[]
}

export default {
  components: {
    BottomNav
  },
  data() {
    return {
      searchKeyword: '',
      activeCategory: 'all',
      activeSort: 'default', // default, sales, price_asc, price_desc
      cartCount: 0,
      isLoading: false,
      hasMore: true,
      pageNum: 1,
      pageSize: 20,
      listType: '', // special, discount, new, recommend
      categoryId: 0,
      categories: [
        { id: 'vegetable', name: '蔬菜' },
        { id: 'fruit', name: '水果' },
        { id: 'meat', name: '肉禽' },
        { id: 'seafood', name: '水产' },
        { id: 'dairy', name: '乳品' },
        { id: 'snack', name: '零食' }
      ] as CategoryType[],
      products: [] as ProductType[], // 原始数据
      displayProducts: [] as ProductType[] // 展示数据 (本Demo简单起见，主要通过计算属性过滤，实际应后端分页)
    }
  },
  onShow() {
    uni.$emit('bottomNavRefresh')
  },
  computed: {
    filteredProducts() : ProductType[] {
      // 直接返回products，排序和筛选由后端处理
      return this.products
    }
  },
  onLoad(options) {
    // 使用 UTSJSONObject 兼容 UTS 语法
    const opts = options as UTSJSONObject
    
    // 接收搜索关键词
    const keyword = opts.get('keyword')
    if (keyword != null) {
      this.searchKeyword = keyword as string
    }
    
    // 接收列表类型（special, discount, new, recommend）
    const type = opts.get('type')
    if (type != null) {
      this.listType = type as string
    }
    
    // 接收分类ID
    const categoryId = opts.get('categoryId')
    if (categoryId != null) {
      this.categoryId = parseInt(categoryId as string)
    }
    
    // 兼容旧的category参数
    const category = opts.get('category')
    if (category != null) {
      this.activeCategory = category as string
    }
    
    this.loadData()
    this.updateCartCount()
  },
  methods: {
    // 检查商品是否有标签
    hasTags(product : ProductType) : boolean {
      const tags = product.tags
      return tags != null && tags.length > 0
    },
    loadData() {
      this.isLoading = true
      
      // 构建搜索参数
      const params = {
        pageNum: this.pageNum,
        pageSize: this.pageSize,
        status: 1
      } as UTSJSONObject
      
      // 添加搜索关键词
      if (this.searchKeyword != '') {
        params.set('keyword', this.searchKeyword)
      }
      
      // 添加分类ID
      if (this.categoryId > 0) {
        params.set('categoryId', this.categoryId)
      }
      
      // 根据列表类型添加筛选条件
      if (this.listType === 'special') {
        // 县域特色 - 可以根据实际业务添加特定标签
      } else if (this.listType === 'discount') {
        // 限时特惠 - 筛选有折扣的商品
      } else if (this.listType === 'new') {
        params.set('isNew', 1)
      } else if (this.listType === 'recommend') {
        params.set('isRecommended', 1)
      }
      
      // 添加排序参数
      if (this.activeSort === 'sales') {
        params.set('sortBy', 'sales')
        params.set('sortOrder', 'desc')
      } else if (this.activeSort === 'price_asc') {
        params.set('sortBy', 'price')
        params.set('sortOrder', 'asc')
      } else if (this.activeSort === 'price_desc') {
        params.set('sortBy', 'price')
        params.set('sortOrder', 'desc')
      }
      
      // 调用后端搜索接口
      post('/products/search', params).then((res) => {
        const data = res.data as UTSJSONObject
        const records = data.getArray('records')
        if (records != null && records.length > 0) {
          const products : ProductType[] = []
          for (let i = 0; i < records.length; i++) {
            const item = records[i] as UTSJSONObject
            const tags : string[] = []
            const isNew = item.getBoolean('isNew') ?? false
            const isHot = item.getBoolean('isHot') ?? false
            const isRecommended = item.getBoolean('isRecommended') ?? false
            
            if (isNew) tags.push('新品')
            if (isHot) tags.push('热销')
            if (isRecommended) tags.push('推荐')
            
            products.push({
              id: (item.getNumber('id') ?? 0).toInt(),
              name: item.getString('productName') ?? '',
              description: item.getString('description') ?? '',
              image: item.getString('mainImage') ?? '',
              price: item.getNumber('currentPrice') ?? 0,
              originalPrice: item.getNumber('originalPrice'),
              sales: (item.getNumber('salesVolume') ?? 0).toInt(),
              category: 'all',
              tags: tags
            } as ProductType)
          }
          this.products = products
        }
        this.isLoading = false
      }).catch((err) => {
        console.error('获取商品列表失败:', err)
        this.isLoading = false
      })
    },
    handleSearch() {
      // 重新加载数据
      this.pageNum = 1
      this.products = []
      this.loadData()
    },
    selectCategory(id : string) {
      this.activeCategory = id
    },
    selectSort(type : string) {
      this.activeSort = type
      // 重新加载数据
      this.pageNum = 1
      this.products = []
      this.loadData()
    },
    togglePriceSort() {
      if (this.activeSort === 'price_asc') {
        this.activeSort = 'price_desc'
      } else {
        this.activeSort = 'price_asc'
      }
      // 重新加载数据
      this.pageNum = 1
      this.products = []
      this.loadData()
    },
    loadMore() {
      // 实际应加载更多页数据
      if (!this.isLoading) {
        console.log('Load More...')
      }
    },
    goToDetail(id : number) {
      uni.navigateTo({ url: `/pages/product/detail?id=${id}` })
    },
    addToCart(product : ProductType) {
      // 先获取商品详情以获取SKU ID
      getProductDetail(product.id).then((res) => {
        const data = res.data as UTSJSONObject
        let skuId = product.id // 默认使用商品ID
        
        // 尝试获取第一个SKU的ID
        const skuArr = data.getArray('skuList')
        if (skuArr != null && skuArr.length > 0) {
          const firstSku = skuArr[0] as UTSJSONObject
          skuId = (firstSku.getNumber('id') ?? product.id).toInt()
        }
        
        const params : CartAddParams = {
          productId: product.id,
          skuId: skuId,
          quantity: 1
        }
        console.log('添加购物车参数:', JSON.stringify(params))
        
        // 嵌套调用添加购物车API
        addToCartApi(params).then((_addRes) => {
          uni.showToast({ title: '已加入购物车', icon: 'success' })
          this.cartCount++
          uni.$emit('bottomNavRefresh')
        }).catch((addErr) => {
          console.error('添加购物车失败:', addErr)
          uni.showToast({ title: '添加失败', icon: 'none' })
        })
      }).catch((err) => {
        console.error('获取商品详情失败:', err)
        uni.showToast({ title: '添加失败', icon: 'none' })
      })
    },
    goToCart() {
      uni.navigateTo({ url: '/pages/cart/index' })
    },
    updateCartCount() {
      // 从API获取购物车数量
      getCartCount().then((res) => {
        const count = (res.data as number | null) ?? 0
        this.cartCount = count as number
      }).catch((err) => {
        console.error('获取购物车数量失败:', err)
        this.cartCount = 0
      })
    }
  }
}
</script>

