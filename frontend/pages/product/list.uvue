  flex-direction: column;
}

/* 顶部搜索 */
.header {
  background-color: #fff;
  padding: 8px 16px;
  /* 拆解 calc，保留状态栏高度 */
  padding-top: var(--status-bar-height);
}

.search-bar {
  background-color: #f2f2f2;
  border-radius: 20px;
  height: 36px;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 12px;
  
  .search-icon {
    font-size: 16px;
    color: #999;
    margin-right: 8px;
  }
  
  .search-input {
    flex: 1;
    font-size: 14px;
    color: #333;
  }
}

/* 筛选工具栏 */
.filter-bar {
  background-color: #fff;
  border-bottom: 1px solid #eee;
  z-index: 10;
}

.category-scroll {
  white-space: nowrap;
  border-bottom: 1px solid #f9f9f9;
}

.category-tabs {
  display: flex;
  flex-direction: row;
  padding: 0 8px;
}

.tab-item {
  position: relative;
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-text {
  font-size: 14px;
  color: #666;
}

.tab-text-active {
  color: #0066CC;
  font-weight: 700;
  font-size: 15px;
}

.active-line {
  position: absolute;
  bottom: 6px;
  width: 20px;
  height: 3px;
  background-color: #0066CC;
  border-radius: 2px;
}

.sort-tabs {
  display: flex;
  flex-direction: row;
  height: 40px;
  align-items: center;
}

.sort-item {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  color: #666;
}

.sort-item-active {
  color: #0066CC;
  font-weight: 400;
}

.sort-arrows {
  display: flex;
  flex-direction: column;
  margin-left: 4px;
}

.arrow {
  font-size: 8px;
  line-height: 8px;
  color: #ccc;
}

.arrow-on {
  color: #0066CC;
}

.arrow-up {
  margin-bottom: -1px;
}

/* 商品列表 */
.product-scroll {
  flex: 1;
  background-color: #f7f8fa;
}

.product-list {
  padding: 10px 12px;
}

.product-item {
  display: flex;
  flex-direction: row;
  background-color: #fff;
  border-radius: 12px;
  padding: 10px;
  margin-bottom: 10px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.02);
  
  .product-img {
    width: 100px;
    height: 100px;
    border-radius: 8px;
    flex-shrink: 0;
    background-color: #f9f9f9;
  }
  
  .product-content {
    flex: 1;
    margin-left: 12px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    
    .info-top {
      .product-name {
        font-size: 15px;
        /* 600 改为 700，作为标题较粗显示 */
        font-weight: 700;
        color: #333;
        margin-bottom: 4px;
        overflow: hidden;
        white-space: normal;
        line-height: 1.4;
        max-height: 40px;
      }
      
      .product-desc {
        font-size: 12px;
        color: #999;
        margin-bottom: 6px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      
      .product-tags {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        
        .tag {
          font-size: 10px;
          color: #ff4d4f;
          border: 1px solid rgba(255, 77, 79, 0.3);
          padding: 1px 4px;
          border-radius: 4px;
          background-color: rgba(255, 77, 79, 0.05);
        }
      }
    }
    
    .info-bottom {
      display: flex;
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
      
      .price-box {
        color: #ff4d4f;
        
        .currency {
          font-size: 12px;
          font-weight: bold;
        }
        
        .price {
          font-size: 18px;
          font-weight: bold;
        }
        
        .origin-price {
          font-size: 11px;
          color: #ccc;
          margin-left: 4px;
        opacity: 0.8;
        }
      }
      

      .add-btn {
        width: 28px;
        height: 28px;
        background-color: #0066CC;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        
        .add-icon {
          color: #fff;
          font-size: 20px;
          /* 300 改为 400 */
          font-weight: 400;
          margin-top: -2px;
        }
      }
    }
  }
}

.empty-state, .loading-more, .no-more {
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  
  .empty-icon {
    font-size: 40px;
    margin-bottom: 10px;
  }
  
}

.empty-text,
.loading-text,
.no-more-text {
  font-size: 13px;
  color: #999;
}

/* 悬浮购物车 */
.cart-float-btn {
  position: fixed;
  right: 20px;
