import { register } from '@/api/user';
type RegisterForm = {
    __$originalPosition?: UTSSourceMapPosition<"RegisterForm", "pages/register/register.uvue", 141, 6>;
    username: string;
    email: string;
    phone: string;
    password: string;
    confirmPassword: string;
    agreeTerms: boolean;
};
type RegisterErrors = {
    __$originalPosition?: UTSSourceMapPosition<"RegisterErrors", "pages/register/register.uvue", 150, 6>;
    username: string;
    email: string;
    phone: string;
    password: string;
    confirmPassword: string;
    agreement: string;
};
const __sfc__ = defineComponent({
    data() {
        return {
            form: {
                username: '',
                email: '',
                phone: '',
                password: '',
                confirmPassword: '',
                agreeTerms: false
            } as RegisterForm,
            errors: {
                username: '',
                email: '',
                phone: '',
                password: '',
                confirmPassword: '',
                agreement: ''
            } as RegisterErrors,
            showPassword: false,
            showConfirmPassword: false,
            isLoading: false
        };
    },
    computed: {
        strengthLevel(): number {
            const pwd = this.form.password;
            if (pwd == '')
                return 0;
            let score = 0;
            if (pwd.length >= 6)
                score++;
            if (pwd.length >= 8)
                score++;
            if (/[a-z]/.test(pwd) && /[A-Z]/.test(pwd))
                score++;
            if (/[0-9]/.test(pwd))
                score++;
            if (/[^a-zA-Z0-9]/.test(pwd))
                score++;
            if (score <= 2)
                return 1;
            if (score <= 4)
                return 2;
            return 3;
        },
        strengthText(): string {
            const levels = ['', '弱', '中', '强'];
            return levels[this.strengthLevel];
        }
    },
    methods: {
        validateUsername() {
            const username = this.form.username.trim();
            if (username == '') {
                this.errors.username = '请输入用户名';
            }
            else if (username.length < 3) {
                this.errors.username = '用户名至少3个字符';
            }
            else if (username.length > 20) {
                this.errors.username = '用户名最多20个字符';
            }
            else if (!/^[a-zA-Z0-9_]+$/.test(username)) {
                this.errors.username = '用户名只能包含字母、数字和下划线';
            }
            else {
                this.errors.username = '';
            }
        },
        validateEmail() {
            const email = this.form.email.trim();
            if (email == '') {
                this.errors.email = '请输入邮箱';
            }
            else if (!/^[a-zA-Z0-9_.-]+@[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/.test(email)) {
                this.errors.email = '请输入有效的邮箱地址';
            }
            else {
                this.errors.email = '';
            }
        },
        validatePhone() {
            this.form.phone = this.form.phone.replace(/[^0-9]/g, '').slice(0, 11);
            const phone = this.form.phone.trim();
            if (phone == '') {
                this.errors.phone = '请输入手机号';
            }
            else if (!/^1[3-9][0-9]{9}$/.test(phone)) {
                this.errors.phone = '请输入有效的手机号';
            }
            else {
                this.errors.phone = '';
            }
        },
        validatePassword() {
            const password = this.form.password.trim();
            if (password == '') {
                this.errors.password = '请输入密码';
            }
            else if (password.length < 6) {
                this.errors.password = '密码至少6个字符';
            }
            else {
                this.errors.password = '';
            }
            // 更新表单值为去除空格后的值
            this.form.password = password;
            // 如果确认密码不为空，同时触发确认密码验证
            if (this.form.confirmPassword != '') {
                this.validateConfirmPassword();
            }
        },
        validateConfirmPassword() {
            const confirmPassword = this.form.confirmPassword.trim();
            const password = this.form.password.trim();
            if (confirmPassword == '') {
                this.errors.confirmPassword = '请确认密码';
            }
            else if (confirmPassword != password) {
                this.errors.confirmPassword = '两次输入的密码不一致';
            }
            else {
                this.errors.confirmPassword = '';
            }
            // 更新表单值为去除空格后的值
            this.form.confirmPassword = confirmPassword;
            this.form.password = password;
        },
        validateAgreement() {
            if (this.form.agreeTerms == false) {
                this.errors.agreement = '请同意用户协议和隐私政策';
            }
            else {
                this.errors.agreement = '';
            }
        },
        handleRegister() {
            if (this.isLoading) {
                return;
            }
            // 先 trim 所有输入
            this.form.username = this.form.username.trim();
            this.form.email = this.form.email.trim();
            this.form.phone = this.form.phone.trim();
            this.form.password = this.form.password.trim();
            this.form.confirmPassword = this.form.confirmPassword.trim();
            this.validateUsername();
            this.validateEmail();
            this.validatePhone();
            this.validatePassword();
            this.validateConfirmPassword();
            this.validateAgreement();
            // Check if there are any errors
            const hasError = this.errors.username != '' || this.errors.email != '' || this.errors.phone != '' ||
                this.errors.password != '' || this.errors.confirmPassword != '' || this.errors.agreement != '';
            if (hasError) {
                return;
            }
            this.isLoading = true;
            register(this.form.username, this.form.email, this.form.phone, this.form.password, this.form.username, // nickname 使用 username 作为默认值
            this.form.confirmPassword).then((response) => {
                this.isLoading = false;
                uni.showToast({
                    title: '注册成功',
                    icon: 'success'
                });
                setTimeout(() => {
                    uni.navigateTo({
                        url: '/pages/login/login'
                    });
                }, 500);
            }).catch((error) => {
                this.isLoading = false;
                const errMsg = error != null && (error as Error).message != null && (error as Error).message != ''
                    ? (error as Error).message
                    : '注册失败，请稍后重试';
                uni.showToast({
                    title: errMsg,
                    icon: 'none'
                });
            });
        },
        handleViewTerms() {
            uni.showToast({
                title: '用户协议功能开发中',
                icon: 'none'
            });
        },
        handleViewPrivacy() {
            uni.showToast({
                title: '隐私政策功能开发中',
                icon: 'none'
            });
        },
        handleLogin() {
            uni.navigateTo({
                url: '/pages/login/login'
            });
        },
        handleBack() {
            uni.navigateBack();
        }
    }
});
