import { getSellerReviews, replyReview, getSellerProducts } from '@/api/seller';
import type { ReviewVO } from '@/api/review';
const __sfc__ = defineComponent({
    data() {
        return {
            productId: 0,
            productName: '',
            sellerProducts: [] as UTSJSONObject[],
            productNameOptions: [] as string[],
            reviews: [] as ReviewVO[],
            allReviewsPool: [] as ReviewVO[],
            allModeLoaded: false,
            pageNum: 1,
            pageSize: 10,
            searchKeyword: '',
            ratingFilter: 0,
            isLoading: false,
            hasMore: true,
            // 回复弹窗
            showReplyModal: false,
            currentReviewId: 0,
            replyContent: ''
        };
    },
    onLoad(options: any) {
        const opts = options as UTSJSONObject;
        this.productId = parseInt(opts.getString('productId') ?? '0');
        this.productName = opts.getString('productName') ?? '';
        if (this.productName != '') {
            uni.setNavigationBarTitle({ title: `${this.productName}评价管理` });
        }
        this.loadSellerProducts(() => {
            this.loadReviews();
        });
    },
    methods: {
        goBack() {
            uni.navigateBack();
        },
        goToProduct(productId: number) {
            uni.navigateTo({
                url: `/pages/product/detail?id=${productId}`
            });
        },
        loadSellerProducts(done: (() => void) | null = null) {
            getSellerProducts({
                pageNum: 1,
                pageSize: 200,
                status: null,
                keyword: null,
                categoryId: null
            } as ProductQueryParams).then((res) => {
                const data = res.data as UTSJSONObject;
                const records = data.getArray('records');
                const productList: UTSJSONObject[] = [];
                const nameOptions: string[] = [];
                if (records != null) {
                    for (let i = 0; i < records.length; i++) {
                        const item = records[i] as UTSJSONObject;
                        productList.push(item);
                        nameOptions.push(item.getString('productName') ?? `商品${i + 1}`);
                    }
                }
                this.sellerProducts = productList;
                this.productNameOptions = nameOptions;
                if (this.productId < 0) {
                    this.productId = 0;
                }
                if (this.productId === 0) {
                    this.productName = '全部商品';
                }
                if (done != null)
                    done();
            }).catch((err) => {
                console.error('获取商家商品失败:', err, " at pages/seller/reviews.uvue:191");
                if (done != null)
                    done();
            });
        },
        getSelectedProductLabel(): string {
            if (this.productId <= 0)
                return '请选择商品';
            if (this.productName != '')
                return this.productName;
            return `商品ID: ${this.productId}`;
        },
        selectProduct(id: number, name: string) {
            if (id < 0 || this.productId === id)
                return;
            this.productId = id;
            this.productName = name;
            this.handleSearch();
        },
        setFilter(rating: number) {
            if (this.ratingFilter !== rating) {
                this.ratingFilter = rating;
                this.handleSearch();
            }
        },
        handleSearch() {
            this.pageNum = 1;
            this.reviews = [];
            this.hasMore = true;
            if (this.productId === 0) {
                this.allReviewsPool = [] as ReviewVO[];
                this.allModeLoaded = false;
            }
            this.loadReviews();
        },
        toReviewVO(item: UTSJSONObject): ReviewVO {
            return {
                id: (item.getNumber('id') ?? 0).toInt(),
                productId: (item.getNumber('productId') ?? 0).toInt(),
                productName: item.getString('productName') ?? '',
                productMainImage: item.getString('productMainImage') ?? '',
                userId: (item.getNumber('userId') ?? 0).toInt(),
                userNickname: item.getString('userNickname') ?? '',
                userAvatar: item.getString('userAvatar') ?? '',
                orderId: (item.getNumber('orderId') ?? 0).toInt(),
                rating: (item.getNumber('rating') ?? 5).toInt(),
                content: item.getString('content') ?? '',
                images: item.getString('images') ?? '',
                replyContent: item.getString('replyContent'),
                replyTime: item.getString('replyTime'),
                status: (item.getNumber('status') ?? 1).toInt(),
                createTime: item.getString('createTime') ?? ''
            } as ReviewVO;
        },
        applyClientFilters(source: ReviewVO[]): ReviewVO[] {
            let list = source;
            if (this.ratingFilter !== 0) {
                list = list.filter((item): boolean => item.rating === this.ratingFilter);
            }
            if (this.searchKeyword != '') {
                const keyword = this.searchKeyword.toLowerCase();
                list = list.filter((item): boolean => {
                    return item.productName.toLowerCase().includes(keyword) || item.content.toLowerCase().includes(keyword);
                });
            }
            return list;
        },
        loadReviews() {
            if (this.isLoading || !this.hasMore)
                return;
            if (this.productId === 0) {
                this.loadAllProductReviews();
                return;
            }
            this.loadSingleProductReviews();
        },
        loadSingleProductReviews() {
            if (this.productId < 0)
                return;
            this.isLoading = true;
            getSellerReviews(this.productId, this.pageNum, this.pageSize, this.ratingFilter === 0 ? null : this.ratingFilter).then((res) => {
                const data = res.data as UTSJSONObject;
                const records = data.getArray('records');
                const total = (data.getNumber('total') ?? 0).toInt();
                const newReviews: ReviewVO[] = [];
                if (records != null) {
                    for (let i = 0; i < records.length; i++) {
                        newReviews.push(this.toReviewVO(records[i] as UTSJSONObject));
                    }
                }
                const filteredReviews = this.applyClientFilters(newReviews);
                this.reviews = this.pageNum === 1 ? filteredReviews : this.reviews.concat(filteredReviews);
                this.hasMore = this.reviews.length < total && newReviews.length > 0;
                this.pageNum++;
                this.isLoading = false;
            }).catch((err) => {
                console.error('获取评价列表失败:', err, " at pages/seller/reviews.uvue:281");
                this.isLoading = false;
                if (this.pageNum === 1)
                    uni.showToast({ title: '加载失败', icon: 'none' });
            });
        },
        loadAllProductReviews() {
            if (this.sellerProducts.length === 0) {
                this.reviews = [] as ReviewVO[];
                this.hasMore = false;
                return;
            }
            if (this.allModeLoaded) {
                const start = (this.pageNum - 1) * this.pageSize;
                const end = start + this.pageSize;
                const filtered = this.applyClientFilters(this.allReviewsPool);
                this.reviews = filtered.slice(0, end);
                this.hasMore = end < filtered.length;
                this.pageNum++;
                return;
            }
            this.isLoading = true;
            const merged: ReviewVO[] = [];
            const productIds: number[] = [];
            for (let i = 0; i < this.sellerProducts.length; i++) {
                const p = this.sellerProducts[i];
                const id = (p.getNumber('id') ?? 0).toInt();
                if (id > 0) {
                    productIds.push(id);
                }
            }
            const finishAll = () => {
                merged.sort((a, b): number => {
                    if (a.createTime == b.createTime)
                        return 0;
                    return a.createTime > b.createTime ? -1 : 1;
                });
                this.allReviewsPool = merged;
                this.allModeLoaded = true;
                const filtered = this.applyClientFilters(this.allReviewsPool);
                this.reviews = filtered.slice(0, this.pageSize);
                this.hasMore = this.pageSize < filtered.length;
                this.pageNum = 2;
                this.isLoading = false;
            };
            const self = this;
            function fetchByIndex(idx: number) {
                if (idx >= productIds.length) {
                    finishAll();
                    return;
                }
                const id = productIds[idx];
                getSellerReviews(id, 1, 50, null).then((res) => {
                    const data = res.data as UTSJSONObject;
                    const records = data.getArray('records');
                    if (records != null) {
                        for (let j = 0; j < records.length; j++) {
                            merged.push(self.toReviewVO(records[j] as UTSJSONObject));
                        }
                    }
                    fetchByIndex(idx + 1);
                }).catch((err) => {
                    console.error('获取商品评价失败:', err, " at pages/seller/reviews.uvue:343");
                    fetchByIndex(idx + 1);
                });
            }
            fetchByIndex(0);
        },
        loadMore() {
            this.loadReviews();
        },
        getImages(imagesStr: string): string[] {
            if (imagesStr == null || imagesStr == '')
                return [] as string[];
            try {
                const arr = UTSAndroid.consoleDebugError(JSON.parse(imagesStr), " at pages/seller/reviews.uvue:356");
                if (Array.isArray(arr)) {
                    return arr as string[];
                }
            }
            catch (e: any) {
                if (imagesStr.includes(',')) {
                    return imagesStr.split(',');
                }
            }
            return [imagesStr] as string[];
        },
        previewImage(urls: string[], current: number) {
            uni.previewImage({
                urls: urls,
                current: current
            });
        },
        openReplyModal(item: ReviewVO) {
            this.currentReviewId = item.id;
            this.replyContent = '';
            this.showReplyModal = true;
        },
        closeReplyModal() {
            this.showReplyModal = false;
        },
        submitReply() {
            if (this.replyContent.trim() == '') {
                uni.showToast({ title: '请输入回复内容', icon: 'none' });
                return;
            }
            uni.showLoading({ title: '提交中' });
            replyReview(this.currentReviewId, this.replyContent).then((_) => {
                uni.hideLoading();
                uni.showToast({ title: '回复成功', icon: 'success' });
                // 更新本地数据
                const review = this.reviews.find((item): boolean => item.id === this.currentReviewId);
                if (review != null) {
                    review.replyContent = this.replyContent;
                    // 简单格式化时间
                    const now = new Date();
                    review.replyTime = `${now.getFullYear()}-${(now.getMonth() + 1).toString(10).padStart(2, '0')}-${now.getDate().toString(10).padStart(2, '0')} ${now.getHours().toString(10).padStart(2, '0')}:${now.getMinutes().toString(10).padStart(2, '0')}`;
                }
                this.closeReplyModal();
            }).catch((err) => {
                uni.hideLoading();
                console.error('回复失败:', err, " at pages/seller/reviews.uvue:404");
                uni.showToast({ title: '回复失败', icon: 'none' });
            });
        }
    }
