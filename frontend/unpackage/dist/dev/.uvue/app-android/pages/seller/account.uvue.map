  color: #999999;
  margin-bottom: 32rpx;
}

.modal-actions {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn-cancel {
  background-color: #F5F7FA;
  margin-right: 24rpx;
}

.modal-btn-confirm {
  background-color: #0066CC;
}

.btn-text {
  font-size: 30rpx;
  color: #666666;
}

.btn-text-white {
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 700;
}
</style>
