<template>
  <view class="page">
    <!-- 顶部蓝色背景区域 -->
    <view class="header-bg">
      <view class="status-bar"></view>
      <!-- 导航栏 -->
      <view class="nav-bar">
        <view class="nav-back" @click="goBack">
          <text class="back-arrow">‹</text>
        </view>
        <text class="nav-title">商家账户</text>
        <view class="nav-placeholder"></view>
      </view>

      <!-- 账户概览卡片 -->
      <view class="balance-box">
        <view class="balance-header">
          <text class="balance-label">可用余额(元)</text>
          <view class="eye-btn" @click="toggleEye">
            <text class="eye-text">{{ showBalance ? '隐藏' : '显示' }}</text>
          </view>
        </view>
        <view class="balance-amount">
          <text class="amount-symbol">¥</text>
          <text class="amount-num">{{ showBalance ? formatMoney(accountInfo.availableBalance) : '****' }}</text>
        </view>
        <view class="balance-actions">
          <view class="action-btn-primary" @click="handleWithdraw">
            <text class="action-btn-primary-text">提现</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 主内容区 -->
    <scroll-view class="main-scroll" scroll-y="true" :show-scrollbar="false" @scrolltolower="loadMore">
      <!-- 资产统计 -->
      <view class="stats-card">
        <view class="stats-item">
          <text class="stats-num">{{ showBalance ? formatMoney(accountInfo.frozenAmount) : '****' }}</text>
          <text class="stats-name">冻结金额</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-num stats-num-green">{{ showBalance ? formatMoney(accountInfo.totalIncome) : '****' }}</text>
          <text class="stats-name">累计收入</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-num stats-num-orange">{{ showBalance ? formatMoney(accountInfo.totalWithdraw) : '****' }}</text>
          <text class="stats-name">累计提现</text>
        </view>
      </view>

      <!-- 交易记录 -->
      <view class="record-card">
        <view class="record-header">
          <text class="record-title">交易记录</text>
          <view class="filter-tabs">
            <text class="filter-tab" :class="{ 'filter-tab-active': currentFilter == 'all' }" @click="changeFilter('all')">全部</text>
            <text class="filter-tab" :class="{ 'filter-tab-active': currentFilter == 'income' }" @click="changeFilter('income')">收入</text>
            <text class="filter-tab" :class="{ 'filter-tab-active': currentFilter == 'withdraw' }" @click="changeFilter('withdraw')">提现</text>
          </view>
        </view>

        <!-- 加载中 -->
        <view class="loading-box" v-if="isLoading && transactions.length == 0">
          <text class="loading-text">加载中...</text>
        </view>

        <view class="record-list" v-else>
          <view class="record-item" v-for="(item, index) in transactions" :key="index">
            <view class="item-icon" :class="getIconClass(item.type)">
              <text class="icon-text">{{ getIcon(item.type) }}</text>
            </view>
            <view class="item-info">
              <text class="item-title">{{ item.typeDesc }}</text>
              <text class="item-desc" v-if="item.description != ''">{{ item.description }}</text>
              <text class="item-time">{{ formatTime(item.createTime) }}</text>
            </view>
            <text class="item-amount" :class="{ 'item-amount-income': item.amount > 0 }">{{ item.amount > 0 ? '+' : '' }}{{ formatMoney(item.amount) }}</text>
          </view>
        </view>

        <view class="list-footer" v-if="transactions.length > 0">
          <text class="footer-text" v-if="isLoading">加载中...</text>
          <text class="footer-text" v-else-if="!hasMore">— 没有更多了 —</text>
        </view>

        <view class="empty-box" v-if="!isLoading && transactions.length == 0">
          <text class="empty-icon">📝</text>
          <text class="empty-text">暂无交易记录</text>
        </view>
      </view>
    </scroll-view>

    <!-- 提现弹窗 -->
    <view class="modal-mask" v-if="showWithdrawModal" @click="closeWithdrawModal">
      <view class="modal-content" @click.stop="">
        <text class="modal-title">提现</text>
        <view class="withdraw-info">
          <text class="withdraw-label">可提现金额</text>
          <text class="withdraw-available">¥{{ formatMoney(accountInfo.availableBalance) }}</text>
        </view>
        <view class="withdraw-input-box">
          <text class="input-prefix">¥</text>
          <input 
            class="withdraw-input" 
            type="digit" 
            placeholder="请输入提现金额" 
            v-model="withdrawAmount"
            @input="onWithdrawInput"
          />
          <view class="withdraw-all-btn" @click="withdrawAll">
            <text class="withdraw-all-text">全部提现</text>
          </view>
        </view>
        <text class="withdraw-tip" v-if="withdrawError != ''">{{ withdrawError }}</text>
        <text class="withdraw-hint">提现将在1-3个工作日内到账</text>
        <view class="modal-actions">
          <view class="modal-btn modal-btn-cancel" @click="closeWithdrawModal">
            <text class="btn-text">取消</text>
          </view>
          <view class="modal-btn modal-btn-confirm" @click="confirmWithdraw">
            <text class="btn-text-white">确认提现</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</template>


<script lang="uts">
import { getSellerAccount, withdrawBalance, getSellerTransactions, type SellerTransactionParams } from '@/api/seller'

// 账户信息类型
type AccountInfoType = {
  availableBalance: number   // 可用余额
  frozenAmount: number       // 冻结金额
  totalIncome: number        // 累计收入
  totalWithdraw: number      // 累计提现
}

// 交易记录类型
type TransactionItemType = {
  id: number
  transactionNo: string
  type: string
  typeDesc: string
  amount: number
  balanceAfter: number
  relatedOrderNo: string
  description: string
  createTime: string
}

export default {
  data() {
    return {
      isLoading: false,
      showBalance: true,
      currentFilter: 'all',
      
      // 账户信息
      accountInfo: {
        availableBalance: 0,
        frozenAmount: 0,
        totalIncome: 0,
        totalWithdraw: 0
      } as AccountInfoType,
      
      // 交易记录
      transactions: [] as TransactionItemType[],
      pageNum: 1,
      pageSize: 10,
      hasMore: true,
      
      // 提现弹窗
      showWithdrawModal: false,
      withdrawAmount: '',
      withdrawError: ''
    }
  },
  onLoad() {
    this.loadAccountInfo()
    this.loadTransactions()
  },
  onShow() {
    // 每次显示页面时刷新账户信息
    this.loadAccountInfo()
  },
  methods: {
    // 加载账户信息
    loadAccountInfo() {
      getSellerAccount().then((res) => {
        const data = res.data as UTSJSONObject
        this.accountInfo = {
          availableBalance: data.getNumber('availableBalance') ?? data.getNumber('balance') ?? 0,
          frozenAmount: data.getNumber('frozenAmount') ?? 0,
          totalIncome: data.getNumber('totalIncome') ?? 0,
          totalWithdraw: data.getNumber('totalWithdraw') ?? 0
        } as AccountInfoType
      }).catch((err) => {
        console.error('获取账户信息失败:', err)
        uni.showToast({ title: '获取账户信息失败', icon: 'none' })
      })
    },
    
    // 加载交易记录
    loadTransactions() {
      if (this.isLoading) return
      this.isLoading = true
      
      let typeParam: string | null = null
      if (this.currentFilter == 'income') {
        typeParam = 'INCOME'
      } else if (this.currentFilter == 'withdraw') {
        typeParam = 'WITHDRAW'
      }
      
      const params: SellerTransactionParams = {
        type: typeParam,
        startDate: null,
        endDate: null,
        pageNum: this.pageNum,
        pageSize: this.pageSize
      }
      
      getSellerTransactions(params).then((res) => {
        const data = res.data as UTSJSONObject
        const recordsArr = data.getArray('records')
        const total = (data.getNumber('total') ?? 0).toInt()
        
        if (recordsArr != null) {
          const newRecords: TransactionItemType[] = []
          for (let i = 0; i < recordsArr.length; i++) {
            const item = recordsArr[i] as UTSJSONObject
            newRecords.push({
              id: (item.getNumber('id') ?? 0).toInt(),
              transactionNo: item.getString('transactionNo') ?? '',
              type: item.getString('type') ?? '',
              typeDesc: item.getString('typeDesc') ?? this.getTypeDesc(item.getString('type') ?? ''),
              amount: item.getNumber('amount') ?? 0,
              balanceAfter: item.getNumber('balanceAfter') ?? 0,
              relatedOrderNo: item.getString('relatedOrderNo') ?? '',
              description: item.getString('description') ?? '',
              createTime: item.getString('createTime') ?? ''
            } as TransactionItemType)
          }
          
          if (this.pageNum == 1) {
            this.transactions = newRecords
          } else {
            this.transactions = this.transactions.concat(newRecords)
          }
          this.hasMore = this.transactions.length < total
        }
        this.isLoading = false
      }).catch((err) => {
        console.error('获取交易记录失败:', err)
        this.isLoading = false
      })
    },
    
    // 获取类型描述
    getTypeDesc(type: string): string {
      if (type == 'INCOME' || type == 'ORDER_INCOME') return '订单收入'
      if (type == 'WITHDRAW') return '提现'
      if (type == 'REFUND') return '退款'
      if (type == 'SETTLE') return '结算'
      return type
    },
    
    // 加载更多
    loadMore() {
      if (!this.hasMore || this.isLoading) return
      this.pageNum++
      this.loadTransactions()
    },
    
    // 切换筛选
    changeFilter(filter: string) {
      if (this.currentFilter == filter) return
      this.currentFilter = filter
      this.pageNum = 1
      this.transactions = [] as TransactionItemType[]
      this.hasMore = true
      this.loadTransactions()
    },
    
    // 格式化金额
    formatMoney(num: number): string {
      return Math.abs(num).toFixed(2)
    },
    
    // 格式化时间
    formatTime(timeStr: string): string {
      if (timeStr.length >= 16) {
        return timeStr.substring(5, 16)
      }
      return timeStr
    },
    
    // 返回上一页
    goBack() {
      uni.navigateBack()
    },
    
    // 切换余额显示
    toggleEye() {
      this.showBalance = !this.showBalance
    },
    
    // 打开提现弹窗
    handleWithdraw() {
      this.showWithdrawModal = true
      this.withdrawAmount = ''
      this.withdrawError = ''
    },
    
    // 关闭提现弹窗
    closeWithdrawModal() {
      this.showWithdrawModal = false
      this.withdrawAmount = ''
      this.withdrawError = ''
    },
    
    // 提现金额输入
    onWithdrawInput(_e: InputEvent) {
      this.withdrawError = ''
      const amount = parseFloat(this.withdrawAmount)
      if (!isNaN(amount) && amount > this.accountInfo.availableBalance) {
        this.withdrawError = '提现金额不能超过可用余额'
      }
    },
    
    // 全部提现
    withdrawAll() {
      this.withdrawAmount = this.accountInfo.availableBalance.toFixed(2)
      this.withdrawError = ''
    },
    
    // 确认提现
    confirmWithdraw() {
      if (this.withdrawAmount == '') {
        this.withdrawError = '请输入提现金额'
        return
      }
      
      const amount = parseFloat(this.withdrawAmount)
      if (isNaN(amount) || amount <= 0) {
        this.withdrawError = '请输入有效的提现金额'
        return
      }
      
      if (amount > this.accountInfo.availableBalance) {
        this.withdrawError = '提现金额不能超过可用余额'
        return
      }
      
      uni.showLoading({ title: '提现中...' })
      withdrawBalance(amount).then((_res) => {
        uni.hideLoading()
        uni.showToast({ title: '提现申请已提交', icon: 'success' })
        this.closeWithdrawModal()
        // 刷新账户信息和交易记录
        this.loadAccountInfo()
        this.pageNum = 1
        this.transactions = [] as TransactionItemType[]
        this.loadTransactions()
      }).catch((err) => {
        uni.hideLoading()
        console.error('提现失败:', err)
        const errMsg = (err as Error).message
        if (errMsg.includes('余额不足') || errMsg.includes('2002')) {
          this.withdrawError = '可用余额不足'
        } else {
          uni.showToast({ title: errMsg != '' ? errMsg : '提现失败', icon: 'none' })
        }
      })
    },
    
    // 获取图标
    getIcon(type: string): string {
      if (type == 'INCOME' || type == 'ORDER_INCOME') return '💰'
      if (type == 'WITHDRAW') return '💳'
      if (type == 'REFUND') return '↩️'
      if (type == 'SETTLE') return '✅'
      return '📝'
    },
    
    // 获取图标样式类
    getIconClass(type: string): string {
      if (type == 'INCOME' || type == 'ORDER_INCOME') return 'item-icon-income'
      if (type == 'WITHDRAW') return 'item-icon-withdraw'
      if (type == 'REFUND') return 'item-icon-refund'
      return ''
    }
  }
}
</script>


<style lang="scss" scoped>
.page {
  display: flex;
  flex-direction: column;
  background-color: #F5F7FA;
  height: 100%;
}

.header-bg {
  background-color: #0066CC;
  padding-bottom: 80rpx;
}

.status-bar {
  height: var(--status-bar-height);
}

.nav-bar {
  height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 400;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.nav-placeholder {
  width: 80rpx;
}

.balance-box {
  padding: 32rpx;
}

.balance-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.balance-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.eye-btn {
