  flex-direction: row;
  align-items: flex-end;
  margin-bottom: 40rpx;
}

.amount-symbol {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 700;
  margin-right: 8rpx;
  margin-bottom: 12rpx;
}

.amount-num {
  font-size: 72rpx;
  color: #FFFFFF;
  font-weight: 700;
}

