  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #F5F7FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  margin-bottom: 16rpx;
}

.input-prefix {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
