  display: flex;
  flex-direction: row;
}

.action-btn-primary {
  flex: 1;
  height: 80rpx;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn-primary-text {
  font-size: 28rpx;
  color: #0066CC;
  font-weight: 700;
}

.main-scroll {
  flex: 1;
  margin-top: -48rpx;
}

.stats-card {
  margin: 0 32rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.stats-num-green {
  color: #52C41A;
}

.stats-num-orange {
  color: #FF7A45;
}

.stats-name {
  font-size: 24rpx;
  color: #999999;
}

.stats-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #F0F0F0;
}

.record-card {
  margin: 0 32rpx 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
}

.record-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.record-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.filter-tabs {
  display: flex;
  flex-direction: row;
  background-color: #F5F7FA;
  border-radius: 8rpx;
  padding: 4rpx;
}

.filter-tab {
  font-size: 24rpx;
  color: #666666;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
}

.filter-tab-active {
  background-color: #0066CC;
  color: #FFFFFF;
}

.loading-box {
  padding: 60rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

.record-list {
  display: flex;
  flex-direction: column;
}

.record-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

