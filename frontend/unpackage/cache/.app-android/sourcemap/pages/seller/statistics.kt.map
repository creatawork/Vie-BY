  background-color: #f7f8fa;
  display: flex;
  flex-direction: column;
  flex: 1;
  padding-bottom: 20px;
}

/* 数据汇总区域 */
.summary-section {
  background-color: #0066CC;
  padding: 16px;
  padding-top: 66px;
}

.summary-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

