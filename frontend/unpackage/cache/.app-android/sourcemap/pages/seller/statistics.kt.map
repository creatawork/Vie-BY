}

.summary-card {
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 12px;
  padding: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 6px;
  width: 46%;
}

.card-value {
  font-size: 20px;
  font-weight: 700;
  color: #fff;
}

.card-label {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6px;
}

/* 图表区域 */
.chart-section {
  background-color: #fff;
  margin: 12px 16px;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
}

.section-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.section-title {
  font-size: 15px;
  font-weight: 700;
  color: #333;
}

.chart-container {
  min-height: 160px;
}

.chart-wrapper {
  display: flex;
  flex-direction: column;
}

.chart-bars {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: flex-end;
  height: 120px;
  padding: 0 8px;
}

.chart-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  max-width: 40px;
}

.bar-wrapper {
  height: 100px;
