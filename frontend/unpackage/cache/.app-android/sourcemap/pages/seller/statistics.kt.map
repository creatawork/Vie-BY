  text-align: center;
}

.chart-legend {
  display: flex;
  justify-content: flex-end;
  margin-top: 12px;
}

.legend-text {
  font-size: 11px;
  color: #999;
}

.chart-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120px;
}

/* 排行区域 */
.ranking-section {
  background-color: #fff;
  margin: 0 16px 12px;
