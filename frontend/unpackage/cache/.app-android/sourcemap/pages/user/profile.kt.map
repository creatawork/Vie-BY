					<text class="logout-text">退出登录</text>
				</view>
			</view>
			
			<!-- ==================== 卖家视图 ==================== -->
			<view v-if="currentRole == 'seller'">
				<!-- 商家模式状态提示 -->
				<view class="role-status-bar seller-mode">
					<text class="role-icon">🏪</text>
					<text class="role-text role-text-seller">商家模式</text>
				</view>
				
				<!-- 店铺信息卡片 - 现代化设计 -->
				<view class="seller-profile-card">
					<!-- 顶部背景装饰 -->
					<view class="seller-card-bg"></view>
					
					<!-- 主要内容区 -->
					<view class="seller-main-content">
						<!-- 头像和基本信息 -->
						<view class="seller-profile-header">
							<view class="seller-avatar-box">
								<image 
									:key="imageKey"
									:src="getAvatarUrl()"
									class="seller-avatar-img"
									mode="aspectFill"
									@error="handleImageError"
								/>
								<view class="seller-verify-badge">
									<text class="verify-icon">✓</text>
								</view>
							</view>
							
							<view class="seller-basic-info">
								<view class="shop-name-row">
									<text class="shop-name-text">{{ shopName != '' ? shopName : '我的店铺' }}</text>
									<view class="shop-level-tag">
										<text class="level-text">Lv5</text>
									</view>
								</view>
								<text class="seller-id-text">ID: {{ userInfo.username }}</text>
								<view class="seller-rating-row">
									<text class="rating-stars">⭐⭐⭐⭐⭐</text>
									<text class="rating-score">4.8</text>
									<text class="rating-count">(128评价)</text>
								</view>
							</view>
						</view>
						
						<!-- 数据统计卡片组 -->
						<view class="seller-stats-grid">
							<view class="stat-card stat-card-1">
								<text class="stat-icon">📦</text>
								<text class="stat-number">{{ sellerOrderStats['totalCount'] ?? 0 }}</text>
								<text class="stat-label">订单总数</text>
							</view>
							<view class="stat-card stat-card-2">
								<text class="stat-icon">🚚</text>
								<text class="stat-number">{{ sellerOrderStats['waitShipCount'] ?? 0 }}</text>
								<text class="stat-label">待发货</text>
							</view>
							<view class="stat-card stat-card-3">
								<text class="stat-icon">✅</text>
								<text class="stat-number">{{ sellerOrderStats['finishedCount'] ?? 0 }}</text>
								<text class="stat-label">已完成</text>
							</view>
						</view>
					</view>
				</view>
				
				<!-- 管理员入口（仅管理员可见） -->
				<view v-if="isAdmin" class="admin-entry-section">
					<view class="admin-entry-card" @tap="handleAdminNavigate">
						<view class="admin-entry-left">
							<text class="admin-entry-icon">👑</text>
							<view class="admin-entry-info">
								<text class="admin-entry-title">管理员后台</text>
								<text class="admin-entry-desc">平台管理与数据监控</text>
							</view>
						</view>
						<text class="admin-entry-arrow">→</text>
					</view>
				</view>
				
				<!-- 商家服务菜单 -->
				<view class="section-title">商家服务</view>
				<view class="menu-grid">
					<view class="menu-item" @tap="handleSellerNavigate('products')">
						<view class="menu-icon-box menu-icon-box-blue">
							<text class="menu-icon">📦</text>
						</view>
						<text class="menu-label">商品管理</text>
					</view>
					
					<view class="menu-item" @tap="handleSellerNavigate('inventory')">
						<view class="menu-icon-box menu-icon-box-green">
							<text class="menu-icon">📊</text>
						</view>
						<text class="menu-label">库存管理</text>
					</view>

					<view class="menu-item" @tap="handleSellerNavigate('statistics')">
						<view class="menu-icon-box menu-icon-box-purple">
							<text class="menu-icon">📈</text>
						</view>
						<text class="menu-label">销售统计</text>
					</view>
					
					<view class="menu-item" @tap="handleSellerNavigate('account')">
						<view class="menu-icon-box menu-icon-box-red">
							<text class="menu-icon">💰</text>
						</view>
						<text class="menu-label">商家账户</text>
					</view>
					
					<view class="menu-item" @tap="handleSellerNavigate('reviews')">
						<view class="menu-icon-box menu-icon-box-orange">
							<text class="menu-icon">⭐</text>
						</view>
						<text class="menu-label">评价管理</text>
					</view>

				</view>
				
				<!-- 商家提示 -->
				<view class="seller-tips">
					<view class="tips-content">
						<text class="tips-title">💡 经营小贴士</text>
						<text class="tips-desc">及时处理订单，保持良好的发货速度可以提升店铺评分哦~</text>
					</view>
				</view>
				
				<!-- Logout Button -->
				<view class="logout-btn" @tap="handleLogout">
					<text class="logout-icon">🚪</text>
					<text class="logout-text">退出登录</text>
				</view>
			</view>
		</scroll-view>
		
		<!-- 底部导航栏 -->
		<BottomNav />
	</view>
</template>

<script lang="uts">
import { getUserProfile, logout, uploadAvatar } from '@/api/user'
import { getSellerStatus, becomeSeller, getRevenueStatistics, getOrderOverview } from '@/api/seller'
import type { ResponseDataType } from '@/utils/request'
import { getOrderCount } from '@/api/order'
import { getCollectionCount } from '@/api/product'
import { getSellerOrderCount } from '@/api/sellerOrder'
import BottomNav from '@/components/BottomNav.uvue'

type UserInfoType = {
	id : string | number
	avatar : string
	username : string
	email : string
	phone : string
	nickname : string
}

type StatsType = {
	orders : number
	pending : number
	shipped : number
	favorites : number
}

// 卖家经营数据类型（保留用于其他统计）
type SellerStatsType = {
	todaySales : number      // 今日销售额
	pendingShip : number     // 待发货订单数
	pendingSettle : number   // 待结算金额
	productCount : number    // 在售商品数量
}

// 商家订单统计类型
type SellerOrderStatsType = {
	unpaid : number          // 待支付订单数
	unshipped : number       // 待发货订单数
	shipped : number         // 待收货订单数（已发货）
	completed : number       // 已完成订单数
	cancelled : number       // 已取消订单数
	total : number           // 订单总数
}

export default {
	components: {
		BottomNav
	},
	data() {
		return {
			userInfo: {
				id: '12345678',
				avatar: '',
				username: 'testuser',
				email: 'user@example.com',
				phone: '13800138000',
				nickname: '测试用户'
			} as UserInfoType,
			stats: {
				orders: 5,
				pending: 1,
				shipped: 2,
				favorites: 12
			} as StatsType,
			defaultAvatar: '/static/logo.png',
			isLoading: false,
			imageKey: 0,
			// 卖家相关数据属性
			isSeller: false,                           // 是否已开通卖家
			isAdmin: false,                            // 是否是管理员
			currentRole: 'buyer' as string,            // 当前视图身份 'buyer' | 'seller'
			shopName: '' as string,                    // 店铺名称
			sellerStats: {
				todaySales: 0,
				pendingShip: 0,
				pendingSettle: 0,
				productCount: 0
			} as SellerStatsType,
			sellerOrderStats: {
				waitShipCount: 0,
				finishedCount: 0,
				totalCount: 0
			} as UTSJSONObject
		}
	},
	onLoad() {
		this.checkLoginStatus()
		
		// 监听收藏刷新事件
		uni.$on('refreshFavorites', this.loadCollectionCount)
	},
	onUnload() {
		// 移除事件监听
		uni.$off('refreshFavorites', this.loadCollectionCount)
	},
	onShow() {
		// 刷新底部导航栏
		uni.$emit('bottomNavRefresh')
		
		const userInfo = uni.getStorageSync('user_info')
		if (userInfo != null && userInfo != '') {
			try {
				const infoStr = userInfo as string
				const parsed = JSON.parse(infoStr) as UTSJSONObject
				// 更新用户信息
				const id = parsed.getNumber('id')
				const avatar = parsed.getString('avatar')
				const username = parsed.getString('username')
				const email = parsed.getString('email')
				const phone = parsed.getString('phone')
				const nickname = parsed.getString('nickname')
				
				this.userInfo = {
					id: id != null ? id.toInt() : this.userInfo.id,
					avatar: avatar != null ? avatar : this.userInfo.avatar,
					username: username != null ? username : this.userInfo.username,
					email: email != null ? email : this.userInfo.email,
					phone: phone != null ? phone : this.userInfo.phone,
					nickname: nickname != null ? nickname : this.userInfo.nickname
				} as UserInfoType
				
				// 检查卖家身份状态
				this.checkSellerStatus()
				
				// 刷新订单统计数据
				this.loadOrderStats()
			} catch (e) {
				console.error(e)
			}
		} else {
			this.checkLoginStatus()
		}
	},
	methods: {
		getAvatarUrl() : string {
			return this.userInfo.avatar != '' ? this.userInfo.avatar : this.defaultAvatar
		},
		getNickname() : string {
			return this.userInfo.nickname != '' ? this.userInfo.nickname : '未设置昵称'
		},
		getUserId() : string {
			const id = this.userInfo.id
			return id != null && id != '' ? id.toString() : '12345678'
		},
		// 检查卖家身份状态
		checkSellerStatus() {
			// 从本地存储读取卖家状态和管理员状态
			const userInfoStr = uni.getStorageSync('user_info')
			if (userInfoStr != null && userInfoStr != '') {
				try {
					const parsed = JSON.parse(userInfoStr as string) as UTSJSONObject
					const sellerStatus = parsed.getBoolean('isSeller')
					const storedShopName = parsed.getString('shopName')
					const roleCodes = parsed.getArray('roleCodes')
					
					this.isSeller = sellerStatus == true
					this.shopName = storedShopName != null ? storedShopName : ''
					
					// 检查是否是管理员（username为admin或角色包含ADMIN）
					const username = parsed.getString('username')
					if (username == 'admin') {
						this.isAdmin = true
					} else if (roleCodes != null) {
						// 检查角色数组中是否包含管理员角色
						for (let i = 0; i < roleCodes.length; i++) {
							const role = roleCodes[i] as string
							if (role == 'ADMIN' || role == 'admin') {
								this.isAdmin = true
								break
							}
						}
					}
				} catch (e) {
					console.error('解析卖家状态失败:', e)
				}
			}
			
			// 从本地存储读取当前身份视图
			const storedRole = uni.getStorageSync('current_role')
			if (storedRole != null && storedRole != '') {
				const roleStr = storedRole as string
				// 如果是卖家且上次为卖家视图，自动切换到卖家视图
				if (this.isSeller && roleStr == 'seller') {
					this.currentRole = 'seller'
					// 加载卖家经营数据
					this.loadSellerStats()
				} else {
					this.currentRole = 'buyer'
				}
			} else {
				this.currentRole = 'buyer'
			}
			
			// 从服务器获取最新的卖家状态
			getSellerStatus().then((result: ResponseDataType) => {
				if (result.code === 200) {
					const data = result.data as UTSJSONObject
					if (data != null) {
						const serverIsSeller = data.getBoolean('isSeller')
						const serverShopName = data.getString('shopName')
						
						this.isSeller = serverIsSeller == true
						this.shopName = serverShopName != null ? serverShopName : ''
						
						// 更新本地存储
						const userInfoStr2 = uni.getStorageSync('user_info')
						if (userInfoStr2 != null && userInfoStr2 != '') {
							try {
								const info = JSON.parse(userInfoStr2 as string) as UTSJSONObject
								const updatedInfo = {
									id: info.getNumber('id'),
									username: info.getString('username'),
									nickname: info.getString('nickname'),
									avatar: info.getString('avatar'),
									email: info.getString('email'),
									phone: info.getString('phone'),
									roleCodes: info.getAny('roleCodes'),
									isSeller: this.isSeller,
									shopName: this.shopName
								} as UTSJSONObject
								uni.setStorageSync('user_info', JSON.stringify(updatedInfo))
							} catch (e) {
								console.error('更新本地卖家状态失败:', e)
							}
						}
						
						// 如果是卖家且当前为卖家视图，加载经营数据
						if (this.isSeller && this.currentRole == 'seller') {
							this.loadSellerStats()
						}
					}
				}
			}).catch((error: Any | null) => {
				console.error('获取卖家状态失败:', error)
			})
		},
		// 切换买家/卖家视图
		handleSwitchRole() {
			if (!this.isSeller) {
				uni.showToast({ title: '请先开通卖家功能', icon: 'none' })
				return
			}
			
			// 切换身份
			if (this.currentRole == 'buyer') {
				this.currentRole = 'seller'
				// 加载卖家经营数据
				this.loadSellerStats()
			} else {
				this.currentRole = 'buyer'
			}
			
			// 保存当前身份到本地存储
			uni.setStorageSync('current_role', this.currentRole)
			
			// 刷新底部导航栏
			uni.$emit('bottomNavRefresh')
		},
		// 加载卖家经营数据
		loadSellerStats() {
			// 加载收入统计数据
			getRevenueStatistics().then((result) => {
				if (result.code === 200) {
					const data = result.data as UTSJSONObject
					if (data != null) {
						const todaySales = data.getNumber('todaySales')
						const pendingShip = data.getNumber('pendingShipCount')
						const pendingSettle = data.getNumber('pendingSettleAmount')
						const productCount = data.getNumber('productCount')
						
						this.sellerStats = {
							todaySales: todaySales != null ? todaySales : 0,
							pendingShip: pendingShip != null ? pendingShip.toInt() : 0,
							pendingSettle: pendingSettle != null ? pendingSettle : 0,
							productCount: productCount != null ? productCount.toInt() : 0
						} as SellerStatsType
					}
				}
			}).catch((error) => {
				console.error('获取卖家经营数据失败:', error)
			})
			
			// 加载订单统计数据
			this.loadSellerOrderStats()
		},
		// 加载商家订单统计
		loadSellerOrderStats() {
			getOrderOverview().then((result) => {
				if (result.code === 200) {
					const data = result.data as UTSJSONObject
					if (data != null) {
						this.sellerOrderStats = data
					}
				}
			}).catch((error) => {
				console.error('获取商家订单统计失败:', error)
			})
		},
		// 卖家菜单导航
		handleSellerNavigate(type : string) {
			const routes = new Map<string, string>([
				['products', '/pages/seller/products'],
				['inventory', '/pages/seller/inventory'],
				['statistics', '/pages/seller/statistics'],
				['account', '/pages/seller/account'],
				['reviews', '/pages/seller/reviews']
			])
			
			const route = routes.get(type)
			if (route != null && route != '') {
				uni.navigateTo({ url: route as string })
			} else {
				uni.showToast({ title: '功能开发中', icon: 'none' })
			}
		},
		// 管理员后台导航
		handleAdminNavigate() {
			uni.navigateTo({ url: '/pages/admin/index' })
		},
		// 处理开通卖家功能
		handleBecomeSeller() {
			uni.showModal({
				title: '开通卖家功能',
				content: '确定要开通卖家功能吗？开通后您可以在平台上销售商品。',
				editable: true,
				placeholderText: '请输入店铺名称（可选）',
				confirmText: '确认开通',
				cancelText: '取消',
				success: (res) => {
					if (res.confirm) {
						const inputShopName = res.content != null && res.content != '' ? res.content : null
						
						uni.showLoading({ title: '开通中...' })
						
						becomeSeller(inputShopName).then((result : ResponseDataType) => {
							uni.hideLoading()
							
							if (result.code === 200) {
								// 更新本地状态
								this.isSeller = true
								if (inputShopName != null && inputShopName != '') {
									this.shopName = inputShopName!
								}
								
								// 更新本地存储
								const userInfoStr = uni.getStorageSync('user_info')
								if (userInfoStr != null && userInfoStr != '') {
									try {
										const info = JSON.parse(userInfoStr as string) as UTSJSONObject
										const updatedInfo = {
											id: info.getNumber('id'),
											username: info.getString('username'),
											nickname: info.getString('nickname'),
											avatar: info.getString('avatar'),
											email: info.getString('email'),
											phone: info.getString('phone'),
											roleCodes: info.getAny('roleCodes'),
											isSeller: true,
											shopName: this.shopName
										} as UTSJSONObject
										uni.setStorageSync('user_info', JSON.stringify(updatedInfo))
									} catch (e) {
										console.error('更新本地卖家状态失败:', e)
									}
								}
								
								uni.showToast({ 
									title: '开通成功！', 
									icon: 'success',
									duration: 2000
								})
								
								// 刷新页面显示身份切换按钮
								setTimeout(() => {
									this.checkSellerStatus()
								}, 500)
							} else {
								const msg = result.message != null ? result.message : '开通失败'
								uni.showToast({ title: msg, icon: 'error' })
							}
						}).catch((error: Any | null) => {
							uni.hideLoading()
							console.error('开通卖家失败:', error)
							uni.showToast({ title: '开通失败，请稍后重试', icon: 'error' })
						})
					}
				}
			})
		},
		checkLoginStatus() {
			const token = uni.getStorageSync('auth_token')
			if (token == null || token == '') {
				uni.showModal({
					title: '提示',
					content: '请先登录后再访问个人中心',
					showCancel: false,
					success: () => {
						uni.reLaunch({ url: '/pages/login/login' })
					}
				})
				return
			}
			this.loadUserInfo()
		},
		loadUserInfo() {
			getUserProfile().then((result) => {
				if (result.code === 200) {
					const data = result.data as UTSJSONObject
					if (data != null) {
						const id = data.getNumber('id')
						const avatar = data.getString('avatar')
						const username = data.getString('username')
						const email = data.getString('email')
						const phone = data.getString('phone')
						const nickname = data.getString('nickname')
						
						this.userInfo = {
							id: id != null ? id.toInt() : '12345678',
							avatar: avatar != null ? avatar : '',
							username: username != null ? username : '',
							email: email != null ? email : '',
							phone: phone != null ? phone : '',
							nickname: nickname != null ? nickname : ''
						} as UserInfoType

						// 合并保存，避免覆盖丢失 isSeller/shopName/roleCodes 等字段
						const storedInfo = uni.getStorageSync('user_info')
						let roleCodes : Any | null = null
						let isSeller : boolean = false
						let shopName : string = ''
						if (storedInfo != null && storedInfo != '') {
							try {
								const oldInfo = JSON.parse(storedInfo as string) as UTSJSONObject
								roleCodes = oldInfo.getAny('roleCodes')
								isSeller = oldInfo.getBoolean('isSeller') == true
								shopName = oldInfo.getString('shopName') ?? ''
							} catch (e) {
								console.error('解析旧用户信息失败:', e)
							}
						}

						const mergedUserInfo = {
							id: this.userInfo.id,
							username: this.userInfo.username,
							nickname: this.userInfo.nickname,
							avatar: this.userInfo.avatar,
							email: this.userInfo.email,
							phone: this.userInfo.phone,
							roleCodes: roleCodes,
							isSeller: isSeller,
							shopName: shopName
						} as UTSJSONObject
						uni.setStorageSync('user_info', JSON.stringify(mergedUserInfo))
					}
				}
			}).catch((error) => {
				console.error('获取用户信息失败:', error)
				const errStr = error != null ? error.toString() : ''
				const errMsg = errStr != '' ? errStr : ''
				// 检查401状态码或特定的Token错误信息
				if (errMsg != '' && (errMsg.includes('401') || errMsg.includes('Token') || errMsg.includes('过期') || errMsg.includes('无效'))) {
					uni.removeStorageSync('auth_token')
					uni.removeStorageSync('user_info')
					uni.reLaunch({ url: '/pages/login/login' })
				}
			})
			
			// 加载订单统计数据
			this.loadOrderStats()
		},
		loadOrderStats() {
			getOrderCount().then((result) => {
				if (result.code === 200) {
					const data = result.data as UTSJSONObject
					if (data != null) {
						const unpaid = (data.getNumber('unpaid') ?? 0).toInt()
						const unshipped = (data.getNumber('unshipped') ?? 0).toInt()
						const shipped = (data.getNumber('shipped') ?? 0).toInt()
						const completed = (data.getNumber('completed') ?? 0).toInt()
						const total = (data.getNumber('total') ?? 0).toInt()
						
						this.stats = {
							orders: total,           // 全部订单
							pending: unpaid,         // 待付款
							shipped: shipped,        // 待收货
							favorites: this.stats.favorites  // 收藏夹（通过loadCollectionCount更新）
						} as StatsType
					}
				}
			}).catch((error) => {
				console.error('获取订单统计失败:', error)
				// 失败时保持默认值，不影响页面显示
			})
			
			// 加载收藏总数
			this.loadCollectionCount()
		},
		loadCollectionCount() {
			getCollectionCount().then((result) => {
				if (result.code === 200) {
					const count = result.data as number
					this.stats.favorites = count != null ? count : 0
				}
			}).catch((error) => {
				console.error('获取收藏总数失败:', error)
				// 失败时保持默认值，不影响页面显示
			})
		},
		handleImageError() {
			this.userInfo.avatar = this.defaultAvatar
		},
		handleUploadAvatar() {
			uni.showActionSheet({
				itemList: ['拍照', '从相册选择'],
				success: (res) => {
					const type = res.tapIndex === 0 ? 'camera' : 'album'
					uni.chooseImage({
						sourceType: [type],
						count: 1,
						success: (imgRes) => {
							if (imgRes.tempFilePaths.length > 0) {
								this.uploadAvatarFile(imgRes.tempFilePaths[0])
							}
						}
					})
				}
			})
		},
		uploadAvatarFile(filePath : string) {
			if (this.isLoading) return
			this.isLoading = true
			uni.showLoading({ title: '上传中...' })

			uploadAvatar(filePath).then((result) => {
				if (result != null) {
					const code = (result.getNumber('code') ?? 0).toInt()
					if (code === 200) {
						const data = result.getString('data') ?? ''
						this.userInfo.avatar = data
						this.imageKey++

						const storedInfo = uni.getStorageSync('user_info')
						if (storedInfo != null && storedInfo != '') {
							const infoStr = storedInfo as string
							const info = JSON.parse(infoStr) as UTSJSONObject
							const updatedInfo = {
								id: info.getNumber('id') != null ? info.getNumber('id')!.toInt() : 0,
								username: info.getString('username') ?? '',
								nickname: info.getString('nickname') ?? '',
								avatar: data,
								email: info.getString('email') ?? '',
								phone: info.getString('phone') ?? '',
								roleCodes: info.getAny('roleCodes'),
								isSeller: info.getBoolean('isSeller') == true,
								shopName: info.getString('shopName') ?? ''
							} as UTSJSONObject
							uni.setStorageSync('user_info', JSON.stringify(updatedInfo))
						}

						uni.showToast({ title: '头像上传成功', icon: 'success' })
					} else {
						const msg = result.getString('message') ?? '上传失败'
						uni.showToast({ title: msg, icon: 'error' })
					}
				} else {
					uni.showToast({ title: '上传失败', icon: 'error' })
				}
				this.isLoading = false
				uni.hideLoading()
			}).catch((error) => {
				uni.showToast({ title: '上传失败', icon: 'error' })
				this.isLoading = false
				uni.hideLoading()
			})
		},
		handleSettings() {
			uni.navigateTo({ url: '/pages/user/settings' })
		},
		handleNavigate(type : string) {
			const routes = new Map<string, string>([
				['products', '/pages/product/list'],
				['orders', '/pages/order/list'],
				['favorites', '/pages/product/favorites'],
				['history', '/pages/product/history'],
				['reviews', '/pages/user/reviews'],
				['addresses', '/pages/user/address-list'],
				['coupons', '/pages/user/coupons'],
				['wallet', '/pages/user/wallet'],
				['pending', '/pages/order/list?status=pending'],
				['shipped', '/pages/order/list?status=shipped'],
				['service', '/pages/service/chat']
			])

			const route = routes.get(type)
			if (route != null && route != '') {
				uni.navigateTo({ url: route as string })
			} else {
				uni.showToast({ title: '功能开发中', icon: 'none' })
			}
		},
		handleEditProfile() {
			uni.navigateTo({ url: '/pages/user/edit-profile' })
		},
		handleChangePassword() {
			uni.navigateTo({ url: '/pages/user/change-password' })
		},
		handleLogout() {
			uni.showModal({
				title: '退出登录',
				content: '确定要退出登录吗？',
				confirmText: '退出',
				confirmColor: '#FF4D4F',
				success: (res) => {
					if (res.confirm) {
						logout().then(() => {}).catch(() => {})
						uni.removeStorageSync('auth_token')
						uni.removeStorageSync('user_info')
						uni.reLaunch({ url: '/pages/login/login' })
					}
				}
			})
		}
	}
}
</script>

