						</view>
						<text class="menu-label">成为商家</text>
					</view>
				</view>
				
				<!-- 买家提示 -->
				<view class="buyer-tips">
					<view class="tips-content">
						<text class="tips-title">💡 购物小贴士</text>
						<text class="tips-desc">收藏喜欢的商品，及时关注优惠活动，享受更多实惠~</text>
					</view>
				</view>
				
				<!-- Logout Button -->
				<view class="logout-btn" @tap="handleLogout">
